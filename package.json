{
	"name": "night-agents",
	"version": "0.0.0",
	"private": true,
	"description": "Night Agents — self-hosted orchestration of AI coding agents (Household + Members)",
	"workspaces": [
		"shared",
		"household",
		"household/web",
		"member"
	],
	"scripts": {
		"typecheck": "npm run typecheck --workspaces --if-present",
		"lint": "prettier --check \"**/*.{ts,tsx,json,md,yml,yaml}\"",
		"format": "prettier --write \"**/*.{ts,tsx,json,md,yml,yaml}\"",
		"test": "npm run test --workspaces --if-present",
		"dev": "concurrently -n hh,web -c blue,magenta \"npm:dev:household\" \"npm:dev:web\"",
		"dev:household": "npm run dev --workspace @night/household",
		"dev:web": "npm run dev --workspace @night/household-web",
		"dev:member": "npm run dev --workspace @night/member",
		"build:household": "docker compose -f docker-compose.household.yml build",
		"build:member": "docker compose -f docker-compose.member.yml build",
		"up:household": "docker compose -f docker-compose.household.yml up -d",
		"up:member": "docker compose -f docker-compose.member.yml up -d",
		"down:household": "docker compose -f docker-compose.household.yml down",
		"down:member": "docker compose -f docker-compose.member.yml down"
	},
	"devDependencies": {
		"@types/node": "^22.10.0",
		"concurrently": "^9.2.1",
		"drizzle-orm": "^0.45.0",
		"prettier": "^3.4.0",
		"tsx": "^4.19.0",
		"typescript": "^5.7.0",
		"vitest": "^2.1.0"
	},
	"engines": {
		"node": ">=22"
	}
}
