# ============================================================
# Member — autonomous worker.
# Copy to .env.member and fill in the values. Run multiple Member
# containers in parallel by reusing this file (or making variants).
#
# For local `npm run dev:member` (no Docker) you'll typically want to
# override two things:
#   - HOUSEHOLD_URL=ws://localhost:8080   (point at the dev Household)
#   - WORKSPACE_DIR=./workspace           (defaults to /workspace, which
#                                          isn't writable on a normal user
#                                          account; see the WORKSPACE_DIR
#                                          comment below)
# Docker compose overrides both via `environment:` in
# docker-compose.member.yml, so these dev values don't affect Docker.
# ============================================================

# WebSocket URL of the Household. Inside docker-compose: ws://household:8080.
# From a separate host: wss://your-household.example.com.
HOUSEHOLD_URL=ws://household:8080

# Join-token issued by Household (web UI Settings → Tokens, or seeded via
# the TokenStore at startup). The same token can be reused across many
# Member instances — token does not represent an identity, member_id does.
HOUSEHOLD_ACCESS_TOKEN=

# Friendly nickname shown in the dashboard. Need not be unique. Optional —
# defaults to <user>@<hostname>.
MEMBER_NAME=alice

# Comma-separated skills from: implement, review, estimate, respond, summarize.
# Default = all five. Restrict to dedicate cheaper workers to e.g. review only.
MEMBER_SKILLS=implement,review,estimate,respond,summarize

# Hint for dispatch + agent thoroughness: hard | medium | lazy. Default medium.
WORKER_PROFILE=medium

# ----- LLM provider (Anthropic supported in M3; Gemini/OpenAI in M6) -----
AI_PROVIDER=anthropic
AI_MODEL=claude-opus-4-7
AI_API_KEY=

# Set AI_API_KEY=fake to run the offline stub provider. Useful for smoke
# testing the workspace + commit + PR pipeline without burning tokens.

# ----- Self-imposed limits (Member enforces, Household only logs) -----
# Empty = unlimited. Hard wallclock limit is always enforced.
MAX_TOKENS_PER_TASK=
MAX_TOKENS_PER_DAY=
MAX_TASK_DURATION_MINUTES=120

# Workspace volume mountpoint. Default matches the Docker volume
# (`/workspace`); leave it as that for Docker compose. For non-Docker
# `npm run dev:member`, set this to a path your user can write to —
# `./workspace` (relative to `member/`, gitignored) is the convention.
# WORKSPACE_DIR=/workspace

# pino log level
LOG_LEVEL=info
