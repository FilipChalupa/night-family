# ============================================================
# Night Agents — sample environment.
# Copy to .env.household and .env.member as needed.
# ============================================================

# ---- Household (.env.household) ----
HOUSEHOLD_NAME=Somnambulator
PRIMARY_ADMIN_GITHUB_USERNAME=your-github-username

# GitHub OAuth app (for web UI login). Create at:
#   https://github.com/settings/developers → New OAuth App
# Authorization callback URL:
#   http://localhost:8080/auth/github/callback   (or your prod URL)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# 32+ random bytes (base64), used to encrypt secrets in the DB.
#   openssl rand -base64 32
SECRETS_KEY=

LOG_LEVEL=info

# ---- Member (.env.member) ----
HOUSEHOLD_URL=ws://household:8080
HOUSEHOLD_ACCESS_TOKEN=         # join-token from /config/tokens.yaml
MEMBER_NAME=alice               # friendly nickname; need not be unique
MEMBER_SKILLS=implement,review,estimate,respond,summarize
WORKER_PROFILE=medium           # hard | medium | lazy

AI_PROVIDER=anthropic           # anthropic | gemini | openai
AI_MODEL=claude-opus-4-7
AI_API_KEY=

# Self-imposed limits (Household just logs hits; doesn't enforce).
MAX_TOKENS_PER_TASK=
MAX_TOKENS_PER_DAY=
MAX_TASK_DURATION_MINUTES=120
