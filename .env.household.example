# ============================================================
# Household — orchestration server.
# Copy to .env.household and fill in the values.
# ============================================================

# Display name (web UI header + handshake response to Members).
HOUSEHOLD_NAME=Somnambulator

# GitHub login of the root admin. Created in /config/users.yaml on first
# start; cannot be removed. No validation against GitHub — typo it = nobody
# can log in. Required.
PRIMARY_ADMIN_GITHUB_USERNAME=your-github-username

# GitHub OAuth app for web UI login. Create at:
#   https://github.com/settings/developers → New OAuth App
# Authorization callback URL: http://localhost:8080/auth/github/callback
# (use your prod URL in production). Without these, dev-mode allow-all
# applies — admin guard is disabled, fine for single-user local dev only.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# 32 random bytes (base64), used to encrypt PATs and webhook secrets in
# the DB. Generate with `openssl rand -base64 32`. Without this, a static
# dev key is used — DO NOT ship to production without setting this.
SECRETS_KEY=

# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Listen port. Override only if 8080 conflicts.
# PORT=8080

# Persistence. Defaults match the Docker volumes; override for non-Docker dev.
# DATA_DIR=/data
# CONFIG_DIR=/config
