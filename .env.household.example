# ============================================================
# Household — orchestration server.
# Copy to .env.household and fill in the values.
# ============================================================

# Display name (web UI header + handshake response to Members).
HOUSEHOLD_NAME=Somnambulator

# Require GitHub login for the dashboard, read APIs and UI websocket.
# Must be explicitly set to true or false.
# When true, PRIMARY_ADMIN_GITHUB_USERNAME, GITHUB_OAUTH_CLIENT_ID and
# GITHUB_OAUTH_CLIENT_SECRET are all required.
REQUIRE_UI_LOGIN=false

# GitHub login of the root admin. Created in /config/users.yaml on first
# start; cannot be removed. No validation against GitHub — typo it = nobody
# can log in. Required when REQUIRE_UI_LOGIN=true.
PRIMARY_ADMIN_GITHUB_USERNAME=your-github-username

# GitHub OAuth app for web UI login. Create at:
#   https://github.com/settings/developers → New OAuth App
# Authorization callback URL: http://localhost:8080/auth/github/callback
# (use your prod URL in production). Required when REQUIRE_UI_LOGIN=true.
# If REQUIRE_UI_LOGIN=false, OAuth stays optional and the dashboard can be
# used in local dev without login.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Master key for encrypting PATs and webhook secrets in the DB.
# Set this when your secrets manager owns it (k8s secrets, 1Password, …) —
# it then takes precedence over the on-disk key.
# Leave blank and Household will auto-generate `<CONFIG_DIR>/.secrets-key`
# (32 random bytes, mode 0600) on first start and reuse it across restarts.
# Either way: back up `/config` (which holds the key) to avoid losing
# encrypted data in `/data` if the volume is gone.
SECRETS_KEY=

# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Listen port. Override only if 8080 conflicts.
# PORT=8080

# Persistence. Defaults match the Docker volumes; override for non-Docker dev.
# DATA_DIR=/data
# CONFIG_DIR=/config
